<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Dashboard | VulnLab</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <div class="container">

        <div class="navbar">
            <h1>VulnLab</h1>
            <div style="display:flex; align-items:center; gap:15px;">
                <% if (difficulty==='low' ) { %>
                    <span class="badge badge-red">🔴 Low</span>
                    <% } else if (difficulty==='medium' ) { %>
                        <span class="badge badge-yellow">🟡 Medium</span>
                        <% } else { %>
                            <span class="badge badge-green">🟢 High</span>
                            <% } %>
                                <div class="navbar-links">
                                    <a href="/settings">⚙️ Settings</a>
                                    <a href="/learn">📚 Learn</a>
                                    <a href="/auth/logout">Logout</a>
                                </div>
            </div>
        </div>

        <h2>Welcome back, <%= username %> <span class="cursor"></span></h2>
        <p style="color:#555; font-size:0.85rem; margin-bottom:25px;">// session active — user_id linked to your orders
            below</p>

        <div class="warning">
            ⚠ <strong>Vulnerability Active:</strong> Try clicking 🔴 Vulnerable on any order, then manually change the
            ID in the URL to access another user's data.
        </div>

        <h3>📦 My Orders</h3>
        <table>
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Item</th>
                    <th>Price</th>
                    <th>View</th>
                </tr>
            </thead>
            <tbody>
                <% orders.forEach(order=> { %>
                    <tr>
                        <td>#<%= order.id %>
                        </td>
                        <td>
                            <%= order.item_name %>
                        </td>
                        <td>$<%= order.price %>
                        </td>
                        <td>
                            <% if (difficulty==='low' ) { %>
                                <a href="/orders/<%= order.id %>">
                                    <span class="badge badge-red">🔴 View Order</span>
                                </a>
                                <% } else if (difficulty==='medium' ) { %>
                                    <a href="/orders/<%= Buffer.from(String(order.id)).toString('base64') %>">
                                        <span class="badge badge-yellow">🟡 View Order</span>
                                    </a>
                                    <% } else { %>
                                        <a href="/orders/<%= order.uuid %>">
                                            <span class="badge badge-green">🟢 View Order</span>
                                        </a>
                                        <% } %>
                        </td>
                    </tr>
                    <% }) %>
            </tbody>
        </table>

        <div class="footer">⚠ VulnLab — For educational purposes only</div>
    </div>
</body>

</html>